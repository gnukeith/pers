{
  "cli_default_open_behavior": "existing_window",
  "proxy": "",
  "project_panel": {
    "dock": "left",
  },
  "agent": {
    "default_model": {
      "provider": "openrouter",
      "model": "openai/gpt-5.4",
      "enable_thinking": true,
    },
    "dock": "right",
    "flexible": false,
    "favorite_models": [],
    "model_parameters": [],
  },
  "icon_theme": "Catppuccin Mocha",
  "base_keymap": "Cursor",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,

  // Hide Sign In button in the title bar
  "title_bar": {
    "show_sign_in": false,
  },

  // Turn off edit predictions
  "edit_predictions": {
    "provider": "none",
  },

  // Hide collab panel button in the status bar
  "collaboration_panel": {
    "button": false,
  },

  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Tokyo Night",
  },
}
